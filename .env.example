# Firebase web app config — these are public client identifiers, NOT secrets.
# Copy to .env.local (gitignored) for local development.
VITE_FIREBASE_API_KEY=AIzaSyApb-EBpIdItXW0AxuYzs5JIHbvbHt622w
# Custom auth domain (D-002/#9): OAuth redirects land on auth.siapp.app so the
# flow stays on a first-party domain. Must be listed in Auth authorized domains.
VITE_FIREBASE_AUTH_DOMAIN=auth.siapp.app
VITE_FIREBASE_PROJECT_ID=siapp-prod
VITE_FIREBASE_STORAGE_BUCKET=siapp-prod.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1087770923189
VITE_FIREBASE_APP_ID=1:1087770923189:web:2dfbba3061e045fff82efc

# Set to "true" to point the SDK at the local emulator suite (dev builds only).
VITE_USE_EMULATORS=false
