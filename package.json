{
  "name": "siapp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test && node --test scripts/check-bundle-isolation.test.mjs",
    "test:rules": "firebase emulators:exec --only firestore,storage \"pnpm --filter @siapp/rules-tests test:rules\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "firebase-admin": "^13.4.0",
    "firebase-tools": "^15.23.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  }
}
