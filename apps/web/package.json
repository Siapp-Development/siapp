{
  "name": "@siapp/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --mode apex --port 5173",
    "dev:apex": "vite --mode apex --port 5173",
    "dev:dashboard": "vite --mode dashboard --port 5174",
    "dev:admin": "vite --mode admin --port 5175",
    "build": "tsc -b && vite build --mode apex && vite build --mode dashboard && vite build --mode admin",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@siapp/shared": "workspace:*",
    "@siapp/ui": "workspace:*",
    "firebase": "^12.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vitest": "^3.0.0"
  }
}
