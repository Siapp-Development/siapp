rules_version = '2';

// Deny-by-default. #6 laid the read rails; #9 adds the first write rules:
// - Workspace isolation via custom claims (request.auth.token.workspaces[wid])
// - Same-workspace members may READ workspace data (explicit matches only)
// - users/{uid}: owner may create/update their own profile (validated below);
//   claimsUpdatedAt is SERVER-ONLY (stamped by syncMemberClaims)
// - auditLog reads are role-gated to owner/admin (deferred #6 audit item)
// - All other client writes stay denied — member docs are written server-side
//   only (#10 provisioning, #11 invites), which keeps the claims-sync trigger
//   trustworthy; task write rules belong to #13
// - #12 adds: project create/update for owner/admin/pm (lifecycle + summary
//   client-immutable; transitions via the setProjectLifecycle callable)
// - #13 adds: phase + task CRUD for owner/admin/pm (department need-to-know
//   enforced on create/update/delete) and append-only task updates for any
//   member who can see the task (author pinned to caller, source 'web')
// - #11 adds: invites (owner/admin read, server-only writes), departments
//   CRUD for owner/admin, and department need-to-know gating on task /
//   task-update / document reads (20-access-control-departments.md)
// - #14 adds: document metadata writes for owner/admin/pm (create +
//   soft-delete only; bytes live in Storage under storage.rules)
// - #15 adds: duplicatedFromProjectId provenance on project create
//   (create-only — absent from the update allowlist, so immutable)
// - #16 adds: client + collaborator CRUD for owner/admin/pm (no hard
//   deletes; notificationsOptOut / lastTaskAt are SERVER-ONLY — absent from
//   every allowlist, so a firm can never set or clear an opt-out, D-035)
// - magicLinks / phoneIndex are server-only (Admin SDK; D-035)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // O(1) membership check from custom claims — no membership-doc read.
    function isFirmMember(wid) {
      return isSignedIn()
        && request.auth.token.workspaces != null
        && request.auth.token.workspaces[wid] != null;
    }

    // Role gate from custom claims (first used by auditLog reads below).
    function hasRole(wid, roles) {
      return isFirmMember(wid)
        && request.auth.token.workspaces[wid].role in roles;
    }

    // Department need-to-know gate (20-access-control-departments.md, #11).
    // Empty/missing restriction list = unrestricted; owner/admin always see
    // everything; others need at least one matching department in claims.
    function canSeeRestricted(wid, restrictions) {
      return hasRole(wid, ['owner', 'admin'])
        || restrictions.size() == 0
        || restrictions.hasAny(request.auth.token.workspaces[wid].departments);
    }

    // Restriction list of an existing doc, tolerating docs written before
    // the field existed.
    function restrictionsOf(data) {
      return data.get('restrictedToDepartments', []);
    }

    // List-provable variant of canSeeRestricted (#13): references the field
    // directly — no .get() default — so the query prover must constrain
    // restrictedToDepartments. With the .get() default an unconstrained
    // pm/viewer list query was ALLOWED and returned restricted docs.
    function canSeeRestrictedList(wid, data) {
      return hasRole(wid, ['owner', 'admin'])
        || data.restrictedToDepartments.size() == 0
        || data.restrictedToDepartments.hasAny(request.auth.token.workspaces[wid].departments);
    }

    // Siapp internal admin — isAdmin custom claim is set once via the
    // setAdminClaim.ts bootstrap script; never by user-initiated flows.
    function isSiappAdmin() {
      return isSignedIn() && request.auth.token.isAdmin == true;
    }

    // Field validation for own users/{uid} writes. Whitelisted keys only —
    // claimsUpdatedAt is deliberately absent: only the claims-sync trigger
    // (Admin SDK) may set it, because the client uses it as the "refresh your
    // token now" signal.
    function validUserProfile(uid) {
      let d = request.resource.data;
      return d.uid == uid
        && d.email == request.auth.token.email
        && d.displayName is string
        && d.displayName.size() > 0
        && d.locale in ['en']
        && d.createdAt is timestamp
        && d.lastSeenAt is timestamp
        && (!('photoUrl' in d) || d.photoUrl is string)
        && (!('phone' in d) || d.phone is string)
        && (!('defaultWorkspaceId' in d) || d.defaultWorkspaceId is string);
    }

    // Field validation shared by department create/update (#11).
    function validDepartment(depId) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'id', 'name', 'description', 'color', 'createdAt', 'createdBy',
          'memberCount'
        ])
        && d.id == depId
        && d.name is string
        && d.name.size() > 0
        && d.name.size() <= 60
        && (!('description' in d) || d.description is string)
        && (!('color' in d) || d.color is string)
        && d.createdAt is timestamp
        && d.createdBy is string
        && d.memberCount is int;
    }

    // Field validation shared by client create/update (#16). Only the
    // firm-editable keys — notificationsOptOut is validated nowhere on
    // purpose: it is server-only (STOP webhook, D-035).
    function validClientFields() {
      let d = request.resource.data;
      return d.name is string
        && d.name.size() > 0
        && d.name.size() <= 120
        && d.phone is string
        && d.phone.matches('\\+[1-9][0-9]{6,14}')
        && (!('email' in d) || (d.email is string && d.email.size() <= 254))
        && (!('companyName' in d) || (d.companyName is string && d.companyName.size() <= 120))
        && (!('notes' in d) || (d.notes is string && d.notes.size() <= 2000))
        && d.language in ['en', 'ms'];
    }

    // Field validation shared by collaborator create/update (#16).
    // notificationsOptOut and lastTaskAt are deliberately absent (server-only).
    function validCollaboratorFields() {
      let d = request.resource.data;
      return d.name is string
        && d.name.size() > 0
        && d.name.size() <= 120
        && d.phone is string
        && d.phone.matches('\\+[1-9][0-9]{6,14}')
        && (!('email' in d) || (d.email is string && d.email.size() <= 254))
        && (!('company' in d) || (d.company is string && d.company.size() <= 120))
        && (!('trade' in d) || (d.trade is string && d.trade.size() <= 120))
        && d.type in ['individual', 'company']
        && d.status in ['active', 'archived'];
    }

    // Type validation for the client-editable project fields (#12).
    // #16: clientId and clientNameDenorm must be paired — either both empty
    // (no client linked) or both non-empty. No exists() check on clientId
    // (matches the phaseId precedent; a stale id only mislabels the firm's
    // own project inside its own workspace).
    function validProjectFields() {
      let d = request.resource.data;
      return d.name is string
        && d.name.size() > 0
        && d.name.size() <= 120
        && (!('code' in d) || (d.code is string && d.code.size() <= 20))
        && d.status in ['planning', 'active', 'on_hold', 'completed', 'archived']
        && d.clientId is string
        && d.clientNameDenorm is string
        && ((d.clientId == '' && d.clientNameDenorm == '')
          || (d.clientId.size() > 0 && d.clientNameDenorm.size() > 0))
        && d.startDate is timestamp
        && (!('targetEndDate' in d) || d.targetEndDate is timestamp)
        && (!('actualEndDate' in d) || d.actualEndDate is timestamp)
        && d.updatedAt is timestamp;
    }

    // collaboratorsCount is server-maintained; tolerate docs written before
    // the visibility field existed (e.g. starter projects).
    function collabCountOf(data) {
      return data.get('visibility', {}).get('collaboratorsCount', 0);
    }

    // Field validation for firm document uploads (#14). retentionUntil is
    // deliberately absent from the allow-list — not client-writable.
    // deletedAt must be an explicit null: every list query filters on
    // `deletedAt == null`, which does not match missing fields.
    function validDocumentCreate(wid, pid, did) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'id', 'name', 'mimeType', 'sizeBytes', 'storagePath',
          'scope', 'scopeId', 'uploadedBy', 'uploaderType', 'uploadedAt',
          'visibleToClient', 'visibleToCollaboratorIds',
          'restrictedToDepartments', 'scanStatus', 'deletedAt'
        ])
        && d.id == did
        && d.name is string
        && d.name.size() > 0
        && d.name.size() <= 255
        && d.mimeType is string
        && d.sizeBytes is int
        && d.sizeBytes > 0
        && d.sizeBytes <= 25 * 1024 * 1024
        // wid/pid are alphanumeric auto-ids (no regex metachars); the single
        // [^/]+ segment keeps metadata out of client-uploads/ and other
        // nested prefixes.
        && d.storagePath.matches('workspaces/' + wid + '/projects/' + pid + '/[^/]+')
        && d.scope in ['project', 'task']
        && (d.scope == 'project'
          ? d.scopeId == pid
          : (d.scopeId is string && d.scopeId.size() > 0))
        && d.uploadedBy == request.auth.uid
        && d.uploaderType == 'firm_member'
        && d.uploadedAt is timestamp
        && d.visibleToClient is bool
        && d.visibleToCollaboratorIds is list
        && d.visibleToCollaboratorIds.size() == 0
        && d.restrictedToDepartments is list
        && d.restrictedToDepartments.size() <= 10
        && d.scanStatus == 'pending'
        && d.deletedAt == null;
    }

    // Field validation shared by phase create/update (#13).
    function validPhaseFields(phid) {
      let d = request.resource.data;
      return d.keys().hasOnly(['id', 'name', 'order', 'startDate', 'endDate', 'status'])
        && d.id == phid
        && d.name is string
        && d.name.size() > 0
        && d.name.size() <= 80
        && d.order is number
        && d.status in ['todo', 'in_progress', 'done']
        && (!('startDate' in d) || d.startDate is timestamp)
        && (!('endDate' in d) || d.endDate is timestamp);
    }

    // Field validation shared by task create/update (#13). Assignees may be
    // firm users or collaborators (shape enforced per entry is deferred to
    // the client at MVP; lists are size-capped).
    function validTaskFields(tid) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'id', 'title', 'description', 'phaseId', 'status',
          'startDate', 'dueDate', 'completedAt', 'assignees',
          'visibleToClient', 'visibleToCollaboratorIds',
          'restrictedToDepartments', 'sendWhatsapp', 'notify', 'dependsOn',
          'order', 'createdAt', 'updatedAt', 'createdBy'
        ])
        && d.id == tid
        && d.title is string
        && d.title.size() > 0
        && d.title.size() <= 200
        && (!('description' in d) || (d.description is string && d.description.size() <= 5000))
        && (!('phaseId' in d) || d.phaseId is string)
        && d.status in ['todo', 'in_progress', 'blocked', 'done']
        && (!('startDate' in d) || d.startDate is timestamp)
        && (!('dueDate' in d) || d.dueDate is timestamp)
        && (!('completedAt' in d) || d.completedAt is timestamp)
        && d.assignees is list
        && d.assignees.size() <= 20
        && d.visibleToClient is bool
        && d.visibleToCollaboratorIds is list
        && d.restrictedToDepartments is list
        && d.restrictedToDepartments.size() <= 10
        && d.sendWhatsapp is bool
        // #18 (D2): optional trigger/recipient map — exactly these five bool
        // keys when present; absent means server-side defaults apply.
        && (!('notify' in d) || (
          d.notify is map
          && d.notify.keys().hasAll(['statusChange', 'dueSoon', 'blocked', 'toClient', 'toInternal'])
          && d.notify.keys().hasOnly(['statusChange', 'dueSoon', 'blocked', 'toClient', 'toInternal'])
          && d.notify.statusChange is bool
          && d.notify.dueSoon is bool
          && d.notify.blocked is bool
          && d.notify.toClient is bool
          && d.notify.toInternal is bool
        ))
        && d.dependsOn is list
        && d.dependsOn.size() <= 50
        && !d.dependsOn.hasAny([tid])
        && d.order is number
        && d.createdAt is timestamp
        && d.updatedAt is timestamp
        && d.createdBy is string;
    }

    // Firm-staff profile — own doc only. No delete; list stays denied.
    match /users/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'photoUrl', 'phone',
          'defaultWorkspaceId', 'locale', 'createdAt', 'lastSeenAt'
        ])
        && validUserProfile(uid);
      // Updates may see a server-stamped claimsUpdatedAt in the merged doc,
      // but must never introduce or change it (nor rewrite createdAt).
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'photoUrl', 'phone',
          'defaultWorkspaceId', 'locale', 'createdAt', 'lastSeenAt',
          'claimsUpdatedAt'
        ])
        && !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(['claimsUpdatedAt', 'createdAt'])
        && validUserProfile(uid);
      allow delete: if false;
    }

    // Cross-workspace phone lookup — Cloud Function / Admin SDK only.
    match /phoneIndex/{phone} {
      allow read, write: if false;
    }

    match /workspaces/{wid} {
      allow read: if isFirmMember(wid);
      allow write: if false;

      match /members/{memberUid} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }

      // Team invitations (#11). Owner/admin manage invites in the UI, but
      // every mutation goes through the invite callables — the raw token is
      // generated server-side and only its hash is stored, and member docs
      // must stay server-authored for the claims-sync trigger.
      match /invites/{inviteId} {
        allow read: if hasRole(wid, ['owner', 'admin']);
        allow write: if false;
      }

      // Departments (#11): workspace-visible names; owner/admin manage them.
      // memberCount / createdAt / createdBy are server-or-create-only —
      // membership changes go through the setMemberDepartments callable,
      // which recomputes memberCount.
      match /departments/{depId} {
        allow read: if isFirmMember(wid);
        allow create: if hasRole(wid, ['owner', 'admin'])
          && validDepartment(depId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.memberCount == 0;
        allow update: if hasRole(wid, ['owner', 'admin'])
          && validDepartment(depId)
          && !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['id', 'createdAt', 'createdBy', 'memberCount']);
        // Deleting a department with members would strand claim/restriction
        // references — empty it first (memberCount is server-maintained).
        allow delete: if hasRole(wid, ['owner', 'admin'])
          && resource.data.memberCount == 0;
      }

      // Clients (#16): workspace-visible; owner/admin/pm manage them. No
      // hard delete (project.clientId denorms would orphan) and no archive
      // field at MVP — clients are edit-only. notificationsOptOut is
      // server-only: absent from the create allowlist and allowed in the
      // update allowlist only so a server-stamped doc stays editable — the
      // diff check keeps firms from ever writing or clearing it. Only the
      // STOP webhook (Admin SDK) writes it (D-035).
      match /clients/{cid} {
        allow read: if isFirmMember(wid);
        allow create: if hasRole(wid, ['owner', 'admin', 'pm'])
          && request.resource.data.keys().hasOnly([
            'id', 'name', 'phone', 'email', 'companyName', 'language',
            'notes', 'createdAt', 'createdBy'
          ])
          && validClientFields()
          && request.resource.data.id == cid
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdBy == request.auth.uid;
        // The merged doc may carry a server-stamped notificationsOptOut, but
        // the diff must never touch it (nor the identity fields).
        allow update: if hasRole(wid, ['owner', 'admin', 'pm'])
          && request.resource.data.keys().hasOnly([
            'id', 'name', 'phone', 'email', 'companyName', 'language',
            'notes', 'notificationsOptOut', 'createdAt', 'createdBy'
          ])
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'phone', 'email', 'companyName', 'language', 'notes'])
          && validClientFields();
        allow delete: if false;
      }

      // Collaborators (#16): workspace-visible; owner/admin/pm manage them.
      // Removal is archival via `status` (task assignees + phoneIndex refs
      // would orphan on delete). notificationsOptOut and lastTaskAt are
      // server-only: absent from the create allowlist and allowed in the
      // update allowlist only so server-stamped docs stay editable — the
      // diff check keeps firms from ever writing them.
      match /collaborators/{colid} {
        allow read: if isFirmMember(wid);
        allow create: if hasRole(wid, ['owner', 'admin', 'pm'])
          && request.resource.data.keys().hasOnly([
            'id', 'name', 'phone', 'email', 'company', 'trade', 'type',
            'status', 'createdAt', 'invitedBy'
          ])
          && validCollaboratorFields()
          && request.resource.data.id == colid
          && request.resource.data.status == 'active'
          && request.resource.data.createdAt is timestamp
          && request.resource.data.invitedBy == request.auth.uid;
        allow update: if hasRole(wid, ['owner', 'admin', 'pm'])
          && request.resource.data.keys().hasOnly([
            'id', 'name', 'phone', 'email', 'company', 'trade', 'type',
            'status', 'notificationsOptOut', 'lastTaskAt', 'createdAt',
            'invitedBy'
          ])
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'phone', 'email', 'company', 'trade', 'type', 'status'])
          && validCollaboratorFields();
        allow delete: if false;
      }

      // Projects (#12): field CRUD is client-side for owner/admin/pm;
      // `lifecycle` + its timestamps, `summary`, and provenance/denorm fields
      // are client-immutable — transitions go through the setProjectLifecycle
      // callable (D-027) and summary through the onTaskWrite trigger.
      match /projects/{pid} {
        allow read: if isFirmMember(wid);
        allow create: if hasRole(wid, ['owner', 'admin', 'pm'])
          && request.resource.data.keys().hasOnly([
            'id', 'name', 'code', 'vertical', 'lifecycle', 'status',
            'clientId', 'clientNameDenorm', 'ownerUid', 'ownerNameDenorm',
            'startDate', 'targetEndDate', 'actualEndDate',
            'summary', 'visibility', 'createdAt', 'updatedAt', 'createdBy',
            'duplicatedFromProjectId'
          ])
          && validProjectFields()
          // #15 duplicate provenance — create-only (immutable via the update
          // allowlist), non-empty string when present.
          && (!('duplicatedFromProjectId' in request.resource.data)
            || (request.resource.data.duplicatedFromProjectId is string
              && request.resource.data.duplicatedFromProjectId.size() > 0))
          && request.resource.data.id == pid
          && request.resource.data.vertical in ['construction', 'legal', 'other']
          && request.resource.data.lifecycle == 'draft'
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerNameDenorm is string
          && request.resource.data.createdAt is timestamp
          && request.resource.data.summary.keys().hasOnly([
            'totalTasks', 'doneTasks', 'overdueTasks', 'progressPct'
          ])
          && request.resource.data.summary.totalTasks == 0
          && request.resource.data.summary.doneTasks == 0
          && request.resource.data.summary.overdueTasks == 0
          && request.resource.data.summary.progressPct == 0
          && request.resource.data.visibility.keys().hasOnly([
            'clientCanSee', 'collaboratorsCount'
          ])
          && request.resource.data.visibility.clientCanSee is bool
          && request.resource.data.visibility.collaboratorsCount == 0;
        // Completed projects are read-only client-side (re-open first);
        // archived/deleted are read-only outright (D-027 table).
        allow update: if hasRole(wid, ['owner', 'admin', 'pm'])
          && resource.data.lifecycle in ['draft', 'published']
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name', 'code', 'clientId', 'clientNameDenorm', 'status',
            'startDate', 'targetEndDate', 'actualEndDate', 'visibility',
            'updatedAt'
          ])
          && validProjectFields()
          && collabCountOf(request.resource.data) == collabCountOf(resource.data)
          // visibility, when present, must keep its exact shape; it may only
          // be absent on legacy docs that never had it (cannot be removed).
          && ('visibility' in request.resource.data
            ? (request.resource.data.visibility.keys().hasOnly([
                'clientCanSee', 'collaboratorsCount'
              ])
              && request.resource.data.visibility.clientCanSee is bool)
            : !('visibility' in resource.data));
        // Soft delete only — `delete` action on the lifecycle callable.
        allow delete: if false;

        // Phases (#13): owner/admin/pm manage the project's phase structure.
        match /phases/{phid} {
          allow read: if isFirmMember(wid);
          allow create, update: if hasRole(wid, ['owner', 'admin', 'pm'])
            && validPhaseFields(phid);
          allow delete: if hasRole(wid, ['owner', 'admin', 'pm']);
        }

        // Department need-to-know (#11): restricted tasks are readable only
        // by owner/admin or members of a listed department. List queries
        // over tasks must therefore constrain restrictedToDepartments
        // client-side (rules for `list` are proven against the query).
        // #13 opens the write path for owner/admin/pm — you can never
        // create, update into, or delete a task you couldn't see.
        match /tasks/{tid} {
          allow get: if isFirmMember(wid)
            && canSeeRestricted(wid, restrictionsOf(resource.data));
          allow list: if isFirmMember(wid)
            && canSeeRestrictedList(wid, resource.data);
          allow create: if hasRole(wid, ['owner', 'admin', 'pm'])
            && validTaskFields(tid)
            && canSeeRestricted(wid, request.resource.data.restrictedToDepartments)
            && request.resource.data.createdBy == request.auth.uid;
          allow update: if hasRole(wid, ['owner', 'admin', 'pm'])
            && validTaskFields(tid)
            && canSeeRestricted(wid, restrictionsOf(resource.data))
            && canSeeRestricted(wid, request.resource.data.restrictedToDepartments)
            && !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['id', 'createdAt', 'createdBy']);
          // Hard delete (no task soft-delete in the data model); the
          // onTaskWrite trigger recomputes project.summary.
          allow delete: if hasRole(wid, ['owner', 'admin', 'pm'])
            && canSeeRestricted(wid, restrictionsOf(resource.data));

          // Updates inherit the parent task's restriction (one get()).
          // Append-only activity stream (#13): any member who can see the
          // task may append; author fields are pinned to the caller and
          // web-sourced actions only — WA/system entries are server-written.
          match /updates/{updid} {
            allow read: if isFirmMember(wid)
              && canSeeRestricted(wid, restrictionsOf(
                get(/databases/$(database)/documents/workspaces/$(wid)/projects/$(pid)/tasks/$(tid)).data
              ));
            allow create: if isFirmMember(wid)
              && canSeeRestricted(wid, restrictionsOf(
                get(/databases/$(database)/documents/workspaces/$(wid)/projects/$(pid)/tasks/$(tid)).data
              ))
              && request.resource.data.keys().hasOnly([
                'id', 'authorType', 'authorId', 'authorNameDenorm',
                'source', 'action', 'payload', 'createdAt'
              ])
              && request.resource.data.id == updid
              && request.resource.data.authorType == 'user'
              && request.resource.data.authorId == request.auth.uid
              && request.resource.data.authorNameDenorm is string
              && request.resource.data.source == 'web'
              && request.resource.data.action in
                ['comment', 'status_change', 'eta_change', 'assigned',
                 'doc_added', 'doc_deleted']
              && request.resource.data.payload is map
              && (request.resource.data.action != 'comment'
                || (request.resource.data.payload.text is string
                  && request.resource.data.payload.text.size() > 0
                  && request.resource.data.payload.text.size() <= 5000))
              && request.resource.data.createdAt is timestamp;
            allow update, delete: if false;
          }
        }

        // Documents (#14): metadata for Storage uploads. Firm owner/admin/pm
        // create (you can never create a doc you couldn't see) and soft-delete
        // (the only permitted update — no rename, no scanStatus writes; the
        // Storage object is immutable and stays for retention). Hard delete
        // denied. retentionUntil/scanStatus transitions are server-side.
        match /documents/{did} {
          allow get: if isFirmMember(wid)
            && canSeeRestricted(wid, restrictionsOf(resource.data));
          allow list: if isFirmMember(wid)
            && canSeeRestrictedList(wid, resource.data);
          allow create: if hasRole(wid, ['owner', 'admin', 'pm'])
            && canSeeRestricted(wid, request.resource.data.restrictedToDepartments)
            && validDocumentCreate(wid, pid, did);
          allow update: if hasRole(wid, ['owner', 'admin', 'pm'])
            && canSeeRestricted(wid, restrictionsOf(resource.data))
            && resource.data.deletedAt == null
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['deletedAt', 'deletedBy', 'deletedByType'])
            && request.resource.data.deletedAt is timestamp
            && request.resource.data.deletedBy == request.auth.uid
            && request.resource.data.deletedByType == 'firm_member';
          allow delete: if false;
        }

        match /milestones/{mid} {
          allow read: if isFirmMember(wid);
          allow write: if false;
        }
      }

      // Magic-link token material is server-only — deny even workspace members
      // (D-035, data-model principle 4).
      match /magicLinks/{shortCode} {
        allow read, write: if false;
      }

      match /messages/{mid} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }

      // Audit trail is owner/admin-only reading (20-access-control audit
      // gating; tightened from isFirmMember per the deferred #6 item).
      match /auditLog/{alid} {
        allow read: if hasRole(wid, ['owner', 'admin']);
        allow write: if false;
      }

      match /usageCounters/{period} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }
    }

    // Catch-all: anything not explicitly matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }

    // Siapp internal admin audit log (#10). Client writes are denied;
    // all entries are written by Cloud Functions via the Admin SDK.
    match /adminLog/{alid} {
      allow read: if isSiappAdmin();
      allow write: if false;
    }
  }
}
