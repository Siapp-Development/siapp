rules_version = '2';

// Deny-by-default. #6 laid the read rails; #9 adds the first write rules:
// - Workspace isolation via custom claims (request.auth.token.workspaces[wid])
// - Same-workspace members may READ workspace data (explicit matches only)
// - users/{uid}: owner may create/update their own profile (validated below);
//   claimsUpdatedAt is SERVER-ONLY (stamped by syncMemberClaims)
// - auditLog reads are role-gated to owner/admin (deferred #6 audit item)
// - All other client writes stay denied — member docs are written server-side
//   only (#10 provisioning, #11 invites), which keeps the claims-sync trigger
//   trustworthy; project/task write rules belong to #12
// - magicLinks / phoneIndex are server-only (Admin SDK; D-035)
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // O(1) membership check from custom claims — no membership-doc read.
    function isFirmMember(wid) {
      return isSignedIn()
        && request.auth.token.workspaces != null
        && request.auth.token.workspaces[wid] != null;
    }

    // Role gate from custom claims (first used by auditLog reads below).
    function hasRole(wid, roles) {
      return isFirmMember(wid)
        && request.auth.token.workspaces[wid].role in roles;
    }

    // Siapp internal admin — isAdmin custom claim is set once via the
    // setAdminClaim.ts bootstrap script; never by user-initiated flows.
    function isSiappAdmin() {
      return isSignedIn() && request.auth.token.isAdmin == true;
    }

    // Field validation for own users/{uid} writes. Whitelisted keys only —
    // claimsUpdatedAt is deliberately absent: only the claims-sync trigger
    // (Admin SDK) may set it, because the client uses it as the "refresh your
    // token now" signal.
    function validUserProfile(uid) {
      let d = request.resource.data;
      return d.uid == uid
        && d.email == request.auth.token.email
        && d.displayName is string
        && d.displayName.size() > 0
        && d.locale in ['en']
        && d.createdAt is timestamp
        && d.lastSeenAt is timestamp
        && (!('photoUrl' in d) || d.photoUrl is string)
        && (!('phone' in d) || d.phone is string)
        && (!('defaultWorkspaceId' in d) || d.defaultWorkspaceId is string);
    }

    // Firm-staff profile — own doc only. No delete; list stays denied.
    match /users/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'photoUrl', 'phone',
          'defaultWorkspaceId', 'locale', 'createdAt', 'lastSeenAt'
        ])
        && validUserProfile(uid);
      // Updates may see a server-stamped claimsUpdatedAt in the merged doc,
      // but must never introduce or change it (nor rewrite createdAt).
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'photoUrl', 'phone',
          'defaultWorkspaceId', 'locale', 'createdAt', 'lastSeenAt',
          'claimsUpdatedAt'
        ])
        && !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(['claimsUpdatedAt', 'createdAt'])
        && validUserProfile(uid);
      allow delete: if false;
    }

    // Cross-workspace phone lookup — Cloud Function / Admin SDK only.
    match /phoneIndex/{phone} {
      allow read, write: if false;
    }

    match /workspaces/{wid} {
      allow read: if isFirmMember(wid);
      allow write: if false;

      match /members/{memberUid} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }

      match /departments/{depId} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }

      match /clients/{cid} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }

      match /collaborators/{colid} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }

      match /projects/{pid} {
        allow read: if isFirmMember(wid);
        allow write: if false;

        match /phases/{phid} {
          allow read: if isFirmMember(wid);
          allow write: if false;
        }

        match /tasks/{tid} {
          allow read: if isFirmMember(wid);
          allow write: if false;

          match /updates/{updid} {
            allow read: if isFirmMember(wid);
            allow write: if false;
          }
        }

        match /documents/{did} {
          allow read: if isFirmMember(wid);
          allow write: if false;
        }

        match /milestones/{mid} {
          allow read: if isFirmMember(wid);
          allow write: if false;
        }
      }

      // Magic-link token material is server-only — deny even workspace members
      // (D-035, data-model principle 4).
      match /magicLinks/{shortCode} {
        allow read, write: if false;
      }

      match /messages/{mid} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }

      // Audit trail is owner/admin-only reading (20-access-control audit
      // gating; tightened from isFirmMember per the deferred #6 item).
      match /auditLog/{alid} {
        allow read: if hasRole(wid, ['owner', 'admin']);
        allow write: if false;
      }

      match /usageCounters/{period} {
        allow read: if isFirmMember(wid);
        allow write: if false;
      }
    }

    // Catch-all: anything not explicitly matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }

    // Siapp internal admin audit log (#10). Client writes are denied;
    // all entries are written by Cloud Functions via the Admin SDK.
    match /adminLog/{alid} {
      allow read: if isSiappAdmin();
      allow write: if false;
    }
  }
}
