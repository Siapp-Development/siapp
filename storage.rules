rules_version = '2';

// Project/task document storage (#14). Deny-by-default; the only writable
// area is workspaces/{wid}/projects/{pid}/{fileName} for firm owner/admin/pm.
//
// Reads are workspace-member-wide: department need-to-know is enforced at the
// Firestore metadata layer (documents/{did} rules), and object paths carry
// unguessable uuids — accepted MVP tradeoff, noted in the #14 PR.
//
// Objects are immutable (no update/delete): document removal is a Firestore
// soft delete; bytes stay for retention until a purge job exists.
//
// #21: portal principals (custom-token claims portal.{wid,pid,cid}) may read
// project files and upload to client-uploads/ (≤10MB, client mime allowlist).
// Client-visibility of individual files is enforced at the Firestore metadata
// layer (documents/{did} rules) — same unguessable-uuid tradeoff as reads.
//
// #22: collaborator principals (custom-token claims collab.{wid,pid,tid,colid})
// may upload to collab-uploads/ (≤25MB, collab mime allowlist, D-f) and read
// project files; the portal client may also read collab-uploads/ because
// collaborator uploads inherit the task's visibleToClient (D-029) — per-file
// visibility is enforced at the Firestore metadata layer.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // O(1) membership check from custom claims — same shape as firestore.rules.
    function isFirmMember(wid) {
      return isSignedIn()
        && request.auth.token.workspaces != null
        && request.auth.token.workspaces[wid] != null;
    }

    function hasRole(wid, roles) {
      return isFirmMember(wid)
        && request.auth.token.workspaces[wid].role in roles;
    }

    // Portal principal (#21) — same shape as firestore.rules. Lifecycle
    // re-checks live in the Firestore metadata rules (no cross-service get
    // here); tokens are short-lived and scoped to one project.
    function isPortalClient(wid, pid) {
      return isSignedIn()
        && request.auth.token.portal != null
        && request.auth.token.portal.wid == wid
        && request.auth.token.portal.pid == pid;
    }

    // Collaborator principal (#22) — same shape as firestore.rules.
    // Lifecycle + visibility re-checks live in the Firestore metadata rules.
    function isCollabPrincipal(wid, pid) {
      return isSignedIn()
        && request.auth.token.collab != null
        && request.auth.token.collab.wid == wid
        && request.auth.token.collab.pid == pid;
    }

    // Mirrors ALLOWED_DOCUMENT_MIME_TYPES in @siapp/shared (parity enforced
    // by a rules test). No image/svg+xml — SVGs can carry scripts and the
    // web app previews inline.
    function isAllowedContentType() {
      return request.resource.contentType in [
        'application/pdf',
        'image/png',
        'image/jpeg',
        'image/webp',
        'image/gif',
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
        'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
        'application/vnd.openxmlformats-officedocument.presentationml.presentation',
        'application/msword',
        'application/vnd.ms-excel',
        'application/vnd.ms-powerpoint'
      ];
    }

    // Mirrors CLIENT_ALLOWED_DOCUMENT_MIME_TYPES in @siapp/shared (#21) —
    // tighter than the firm list: no spreadsheets/presentations.
    function isClientAllowedContentType() {
      return request.resource.contentType in [
        'application/pdf',
        'image/png',
        'image/jpeg',
        'image/webp',
        'image/gif',
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
        'application/msword'
      ];
    }

    // Firm uploads live directly under the project prefix (single segment —
    // client-uploads/ is deliberately not matched here).
    match /workspaces/{wid}/projects/{pid}/{fileName} {
      allow read: if isFirmMember(wid)
        || isPortalClient(wid, pid)
        // #22: firm files shared with a collaborator (visibleToCollaboratorIds
        // gates the metadata; unguessable-uuid tradeoff as above).
        || isCollabPrincipal(wid, pid);
      allow create: if hasRole(wid, ['owner', 'admin', 'pm'])
        && request.resource.size <= 25 * 1024 * 1024
        && isAllowedContentType();
      allow update, delete: if false;
    }

    // Client portal uploads (#21, D7): portal principals write bytes
    // directly; Firestore metadata (validPortalDocumentCreate) pins the
    // identity fields. Firm members read; objects stay immutable.
    match /workspaces/{wid}/projects/{pid}/client-uploads/{fileName} {
      allow read: if isFirmMember(wid) || isPortalClient(wid, pid);
      allow create: if isPortalClient(wid, pid)
        && request.resource.size <= 10 * 1024 * 1024
        && isClientAllowedContentType();
      allow update, delete: if false;
    }

    // Collaborator uploads (#22, D-f): collab principals write bytes
    // directly; Firestore metadata (validCollabDocumentCreate) pins the
    // identity fields. Firm members and the portal client read (D-029:
    // collaborator uploads inherit the task's client visibility).
    match /workspaces/{wid}/projects/{pid}/collab-uploads/{fileName} {
      allow read: if isFirmMember(wid)
        || isPortalClient(wid, pid)
        || isCollabPrincipal(wid, pid);
      allow create: if isCollabPrincipal(wid, pid)
        && request.resource.size <= 25 * 1024 * 1024
        // COLLAB_ALLOWED_DOCUMENT_MIME_TYPES is identical to the client
        // list, so the same helper serves both (parity via rules test).
        && isClientAllowedContentType();
      allow update, delete: if false;
    }
  }
}
